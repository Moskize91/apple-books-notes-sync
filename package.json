{
  "name": "apple-books-notes-sync",
  "version": "0.1.0",
  "description": "Sync Apple Books highlights and notes to local Markdown files.",
  "main": "dist/cli.js",
  "bin": {
    "absync": "dist/cli.js"
  },
  "files": [
    "dist",
    "tools"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:sync": "tsx src/cli.ts config set output.dir . && tsx src/cli.ts config set output.managedDirName sync && tsx src/cli.ts sync",
    "dev:sync:dry": "tsx src/cli.ts config set output.dir . && tsx src/cli.ts config set output.managedDirName sync && tsx src/cli.ts sync --dry-run",
    "build": "tsup",
    "start": "node dist/cli.js",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "install:local": "npm run build && npm install -g .",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "apple-books",
    "books",
    "highlights",
    "notes",
    "markdown",
    "obsidian",
    "cli"
  ],
  "author": "Moskize91",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moskize91/apple-books-notes-sync.git"
  },
  "bugs": {
    "url": "https://github.com/moskize91/apple-books-notes-sync/issues"
  },
  "homepage": "https://github.com/moskize91/apple-books-notes-sync",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "pdfjs-dist": "^5.4.624",
    "sharp": "^0.34.5"
  }
}
